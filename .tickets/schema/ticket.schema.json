{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SzimplaCoffee Local Ticket",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "priority",
    "status",
    "owner",
    "created_at",
    "updated_at",
    "problem",
    "desired_outcome",
    "scope_in",
    "scope_out",
    "acceptance_criteria",
    "verification_required",
    "slices",
    "delivery"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^SC-[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string"
    },
    "priority": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "desired_outcome": {
      "type": "string",
      "minLength": 1
    },
    "scope_in": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope_out": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1
    },
    "verification_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "object"
    },
    "slices": {
      "type": "array",
      "minItems": 1
    },
    "delivery": {
      "type": "object"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
